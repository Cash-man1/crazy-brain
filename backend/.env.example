# Database
DATABASE_URL=sqlite+aiosqlite:///./crazybrain.db

# Sicurezza
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id

# Email (per reset password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=true
MAIL_SSL=false

# App
APP_NAME=Crazy Brain
APP_URL=https://crazy-brain.it
FRONTEND_URL=https://crazy-brain.it
ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=100/minute

# Trial
TRIAL_DAYS=2
MAX_TRIAL_USERS=100

# Admin telefono (opzionale): seed all'avvio per login POST /api/auth/phone/login
# ADMIN_PHONE_NUMBER=
# ADMIN_PHONE_PASSWORD=

# Admin email (opzionale): creato solo se ADMIN_PASSWORD rispetta PASSWORD_MIN_LENGTH (vedi config.py)
# ADMIN_EMAIL=admin@crazy-brain.local
# ADMIN_PASSWORD=

# Notifiche segnali Telegram (broadcast senza DB: chat id separati da virgola)
# NOTIFY_SIGNALS_ENABLED=true
# NOTIFY_MIN_CONFIDENCE=0.45
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_CHAT_IDS=

# Scraper Playwright (opzionale)
# SCRAPER_SCREENSHOT_KEEP=3
# SCRAPER_TMP_DEBUG=0
# 1 = usa prima API JSON Evolution (leggera); 0 = solo Playwright
# SCRAPER_USE_EVOLUTION_API=1
# 0 = non usare mai Playwright nel processo API (Dockerfile.api / RAM)
# SCRAPER_PLAYWRIGHT_FALLBACK=0
# 1 = leggi righe live da Redis (worker run_live_worker.py)
# LIVE_ROWS_FROM_REDIS=0
# LIVE_ROWS_REDIS_TTL=60

# Cache pubblica dashboard (opzionale): Redis esterno riduce RAM sul dyno (Render Redis, Upstash, ecc.)
# REDIS_URL=redis://default:password@host:6379

# Loop ingestione pubblica all'avvio API (0 = disabilita)
# PUBLIC_INGESTION_ENABLED=1

# Storico giocate persistito (public_history.json): finestra scorrevole ultime N righe (nuove ok, vecchie oltre N eliminate al salvataggio)
# PUBLIC_HISTORY_MAX_ITEMS=5000

# Con Playwright: filtro "Ultime N ore" sulla pagina casino (1, 6, 12, 24, 48, 72)
# SCRAPER_CRONOLOGIA_HOURS=72

# Telegram (notifiche / collegamento chat): stesso secret_token usato in setWebhook, altrimenti lascia vuoto
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# true = rifiuta webhook se manca l'header secret (richiede setWebhook con secret_token)
# TELEGRAM_WEBHOOK_STRICT_SECRET=false
