# Database
DATABASE_URL=sqlite+aiosqlite:///./crazybrain.db

# Sicurezza
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id

# Email (per reset password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=true
MAIL_SSL=false

# App
APP_NAME=Crazy Brain
APP_URL=https://crazy-brain.it
FRONTEND_URL=https://crazy-brain.it
ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=100/minute

# Trial
TRIAL_DAYS=2
MAX_TRIAL_USERS=100

# Admin telefono (opzionale): seed all'avvio per login POST /api/auth/phone/login
# ADMIN_PHONE_NUMBER=3756271339
# ADMIN_PHONE_PASSWORD=

# Scraper Playwright (opzionale)
# SCRAPER_SCREENSHOT_KEEP=3
# SCRAPER_TMP_DEBUG=0
# 1 = usa prima API JSON Evolution (leggera); 0 = solo Playwright
# SCRAPER_USE_EVOLUTION_API=1
